{
    "rewrites": [
      { "source": "/iyp-browser(/.*)", "destination": "/iyp-browser/index.html" }
    ],
    "headers": [
      {
        "source": "/(.*)\\.js",
        "headers": [
          { "key": "Content-Type", "value": "application/javascript" }
        ]
      },
      {
        "source": "/(.*)\\.mjs",
        "headers": [
          { "key": "Content-Type", "value": "application/javascript" }
        ]
      }
    ]
  }